<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Sequence for Student ID -->
        <record id="seq_hostel_student" model="ir.sequence">
            <field name="name">Hostel Student</field>
            <field name="code">hostel.student</field>
            <field name="prefix">STU</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Sequence for Allocation -->
        <record id="seq_hostel_allocation" model="ir.sequence">
            <field name="name">Hostel Allocation</field>
            <field name="code">hostel.allocation</field>
            <field name="prefix">ALL</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Sequence for Fee -->
        <record id="seq_hostel_fee" model="ir.sequence">
            <field name="name">Hostel Fee</field>
            <field name="code">hostel.fee</field>
            <field name="prefix">FEE</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>