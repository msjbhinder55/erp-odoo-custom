<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_hostel_allocation_tree" model="ir.ui.view">
        <field name="name">hostel.allocation.tree</field>
        <field name="model">hostel.allocation</field>
        <field name="arch" type="xml">
            <tree decoration-success="state=='active'" decoration-info="state=='confirmed'" 
                  decoration-muted="state=='completed'" decoration-danger="state=='cancelled'">
                <field name="student_id"/>
                <field name="room_id"/>
                <field name="bed_number"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="state"/>
                <field name="due_amount" widget="monetary"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_hostel_allocation_form" model="ir.ui.view">
        <field name="name">hostel.allocation.form</field>
        <field name="model">hostel.allocation</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" type="object" string="Confirm" 
                            states="draft" class="btn-primary"/>
                    <button name="action_activate" type="object" string="Activate" 
                            states="confirmed" class="btn-primary"/>
                    <button name="action_complete" type="object" string="Complete" 
                            states="active" class="btn-secondary"/>
                    <button name="action_cancel" type="object" string="Cancel" 
                            states="draft,confirmed,active" class="btn-danger"/>
                    <!-- Fixed the button reference -->
                    <button name="%(my_hostel.action_hostel_change_room_wizard)d" type="action" 
                            string="Change Room" states="active" class="btn-secondary"/>
                    <field name="state" widget="statusbar" 
                           statusbar_visible="draft,confirmed,active,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="display_name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="student_id"/>
                            <field name="room_id"/>
                            <field name="bed_number"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                    </group>
                    <group>
                        <group string="Fee Summary">
                            <field name="total_fee" widget="monetary"/>
                            <field name="paid_amount" widget="monetary"/>
                            <field name="due_amount" widget="monetary"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Fees">
                            <group>
                                <button name="action_create_fee" type="object" 
                                        string="Create Fee" class="btn-primary" states="active"/>
                            </group>
                            <field name="fee_ids" mode="tree,form">
                                <tree>
                                    <field name="name"/>
                                    <field name="fee_type"/>
                                    <field name="amount" widget="monetary"/>
                                    <field name="paid_amount" widget="monetary"/>
                                    <field name="due_amount" widget="monetary"/>
                                    <field name="due_date"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes" widget="html"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Search View - FIXED -->
    <record id="view_hostel_allocation_search" model="ir.ui.view">
        <field name="name">hostel.allocation.search</field>
        <field name="model">hostel.allocation</field>
        <field name="arch" type="xml">
            <search>
                <field name="student_id"/>
                <field name="room_id"/>
                <filter name="filter_active" string="Active" domain="[('state', '=', 'active')]"/>
                <filter name="filter_confirmed" string="Confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter name="filter_completed" string="Completed" domain="[('state', '=', 'completed')]"/>
                <separator/>
                <filter name="filter_this_month" string="This Month" date="start_date"/>
                <separator/>
                <filter name="group_by_state" string="State" context="{'group_by': 'state'}"/>
                <!-- Fixed: Use a proper field name for grouping by hostel -->
                <filter name="group_by_hostel" string="Hostel" context="{'group_by': 'room_id'}"/>
                <!-- Alternative: If you want to group by hostel name, you need to add a related field to the model -->
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_hostel_allocation" model="ir.actions.act_window">
        <field name="name">Allocations</field>
        <field name="res_model">hostel.allocation</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_filter_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first allocation!
            </p>
            <p>
                Allocations assign students to rooms. Once allocated,
                you can manage fees and other services for each student.
            </p>
        </field>
    </record>
</odoo>