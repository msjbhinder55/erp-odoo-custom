<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_hostel_student_tree" model="ir.ui.view">
        <field name="name">hostel.student.tree</field>
        <field name="model">hostel.student</field>
        <field name="arch" type="xml">
            <tree>
                <field name="student_id"/>
                <field name="name"/>
                <field name="gender"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="course"/>
                <field name="year_of_study"/>
                <field name="active" invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_hostel_student_form" model="ir.ui.view">
        <field name="name">hostel.student.form</field>
        <field name="model">hostel.student</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="active" invisible="1"/>
                    <button name="toggle_active" type="object" 
                            attrs="{'invisible': [('active', '=', False)]}" 
                            string="Archive" class="btn-secondary"/>
                    <button name="toggle_active" type="object" 
                            attrs="{'invisible': [('active', '=', True)]}" 
                            string="Unarchive" class="btn-secondary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Student Name..."/>
                        </h1>
                        <h2>
                            <field name="student_id" placeholder="Student ID..."/>
                        </h2>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="date_of_birth"/>
                            <field name="age"/>
                            <field name="gender"/>
                            <field name="course"/>
                            <field name="year_of_study"/>
                        </group>
                        <group>
                            <field name="phone" widget="phone"/>
                            <field name="email" widget="email"/>
                            <field name="address" widget="textarea"/>
                            <field name="emergency_contact_name"/>
                            <field name="emergency_contact_phone" widget="phone"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Allocations">
                            <group>
                                <field name="current_allocation_id" widget="many2one" readonly="1"/>
                            </group>
                            <field name="allocation_ids" mode="tree,form">
                                <tree>
                                    <field name="room_id"/>
                                    <field name="bed_number"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes" widget="html"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_hostel_student_search" model="ir.ui.view">
        <field name="name">hostel.student.search</field>
        <field name="model">hostel.student</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="student_id"/>
                <field name="course"/>
                <filter name="filter_male" string="Male" domain="[('gender', '=', 'male')]"/>
                <filter name="filter_female" string="Female" domain="[('gender', '=', 'female')]"/>
                <separator/>
                <filter name="filter_allocated" string="Allocated" 
                        domain="[('current_allocation_id', '!=', False)]"/>
                <filter name="filter_not_allocated" string="Not Allocated" 
                        domain="[('current_allocation_id', '=', False)]"/>
                <separator/>
                <filter name="group_by_course" string="Course" context="{'group_by': 'course'}"/>
                <filter name="group_by_year" string="Year" context="{'group_by': 'year_of_study'}"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_hostel_student" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">hostel.student</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register your first student!
            </p>
            <p>
                Students are the residents of the hostel. Register them here
                and then allocate rooms to manage their accommodation.
            </p>
        </field>
    </record>
</odoo>