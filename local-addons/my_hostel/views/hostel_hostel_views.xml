<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_hostel_hostel_tree" model="ir.ui.view">
        <field name="name">hostel.hostel.tree</field>
        <field name="model">hostel.hostel</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="code"/>
                <field name="phone"/>
                <field name="warden_id"/>
                <field name="total_rooms"/>
                <field name="occupied_rooms"/>
                <field name="available_rooms"/>
                <field name="active" invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_hostel_hostel_form" model="ir.ui.view">
        <field name="name">hostel.hostel.form</field>
        <field name="model">hostel.hostel</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="active" invisible="1"/>
                    <button name="toggle_active" type="object" 
                            attrs="{'invisible': [('active', '=', False)]}" 
                            string="Archive" class="btn-secondary"/>
                    <button name="toggle_active" type="object" 
                            attrs="{'invisible': [('active', '=', True)]}" 
                            string="Unarchive" class="btn-secondary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Hostel Name..."/>
                        </h1>
                        <h2>
                            <field name="code" placeholder="Code..."/>
                        </h2>
                    </div>
                    <group>
                        <group>
                            <field name="warden_id"/>
                            <field name="phone"/>
                            <field name="email"/>
                            <field name="address" widget="textarea"/>
                        </group>
                        <group>
                            <field name="total_rooms"/>
                            <field name="occupied_rooms"/>
                            <field name="available_rooms"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Rooms">
                            <field name="room_ids" mode="tree,form">
                                <tree>
                                    <field name="room_number"/>
                                    <field name="floor"/>
                                    <field name="room_type"/>
                                    <field name="capacity"/>
                                    <field name="current_occupancy"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Description">
                            <field name="description" widget="html"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_hostel_hostel_search" model="ir.ui.view">
        <field name="name">hostel.hostel.search</field>
        <field name="model">hostel.hostel</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="warden_id"/>
                <filter name="filter_available" string="Has Available Rooms" 
                        domain="[('available_rooms', '>', 0)]"/>
                <separator/>
                <filter name="group_by_warden" string="Warden" context="{'group_by': 'warden_id'}"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_hostel_hostel" model="ir.actions.act_window">
        <field name="name">Hostels</field>
        <field name="res_model">hostel.hostel</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_filter_available': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first hostel!
            </p>
            <p>
                Hostels are the main buildings where students will be accommodated.
                Add rooms to each hostel to start managing allocations.
            </p>
        </field>
    </record>
</odoo>