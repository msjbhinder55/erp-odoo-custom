<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View - FIXED -->
    <record id="view_hostel_fee_tree" model="ir.ui.view">
        <field name="name">hostel.fee.tree</field>
        <field name="model">hostel.fee</field>
        <field name="arch" type="xml">
            <!-- Fixed: Escaped < character with &lt; -->
            <tree decoration-success="state=='paid'" 
                  decoration-danger="due_amount>0 and due_date&lt;current_date" 
                  decoration-warning="due_amount>0 and state!='paid'">
                <field name="name"/>
                <field name="student_id"/>
                <field name="fee_type"/>
                <field name="amount" widget="monetary"/>
                <field name="paid_amount" widget="monetary"/>
                <field name="due_amount" widget="monetary"/>
                <field name="due_date"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_hostel_fee_form" model="ir.ui.view">
        <field name="name">hostel.fee.form</field>
        <field name="model">hostel.fee</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" type="object" string="Confirm" 
                            states="draft" class="btn-primary"/>
                    <button name="action_paid" type="object" string="Mark as Paid" 
                            states="confirmed" class="btn-primary"/>
                    <button name="action_cancel" type="object" string="Cancel" 
                            states="draft,confirmed" class="btn-danger"/>
                    <button name="action_register_payment" type="object" string="Register Payment" 
                            states="confirmed" class="btn-secondary"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,paid"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Fee Description..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="student_id"/>
                            <field name="allocation_id"/>
                            <field name="fee_type"/>
                        </group>
                        <group>
                            <field name="amount" widget="monetary"/>
                            <field name="paid_amount" widget="monetary"/>
                            <field name="due_amount" widget="monetary"/>
                            <field name="due_date"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" widget="html"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_hostel_fee_search" model="ir.ui.view">
        <field name="name">hostel.fee.search</field>
        <field name="model">hostel.fee</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="student_id"/>
                <!-- Fixed: Escaped < character with &lt; -->
                <filter name="filter_overdue" string="Overdue" 
                        domain="[('due_amount', '>', 0), ('due_date', '&lt;', current_date)]"/>
                <filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="filter_confirmed" string="Confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter name="filter_paid" string="Paid" domain="[('state', '=', 'paid')]"/>
                <separator/>
                <filter name="group_by_type" string="Fee Type" context="{'group_by': 'fee_type'}"/>
                <filter name="group_by_state" string="State" context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_hostel_fee" model="ir.actions.act_window">
        <field name="name">Fees</field>
        <field name="res_model">hostel.fee</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_filter_confirmed': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first fee entry!
            </p>
            <p>
                Manage all hostel-related fees including rent, deposits, and service charges.
            </p>
        </field>
    </record>
</odoo>